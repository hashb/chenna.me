# HTTP server
BIND_ADDR=127.0.0.1
PORT=8080

# Local path to the checked-out chenna.me repo
REPO_PATH=/home/your-user/src/chenna.me

# Google Cloud Storage
GCS_BUCKET=your-gcs-bucket
GCS_PREFIX=photos/prod/opt/micro
IMAGE_BASE_URL=//i.chenna.me/photos/prod/opt/micro
GOOGLE_APPLICATION_CREDENTIALS=/home/your-user/.config/gcloud/micropub-service-account.json

# IndieWeb / CORS
SITE_URL=https://chenna.me
# Public Micropub/media endpoint base URL. Leave equal to SITE_URL unless the service is hosted elsewhere.
ENDPOINT_URL=https://micropub.chenna.me
TOKEN_ENDPOINT=https://tokens.indieauth.com/token
ALLOWED_ORIGINS=https://chenna.me,http://localhost:4000

# Optional reverse-proxy TLS on the VM for Cloudflare Full (strict)
# ORIGIN_CERT_PATH=/etc/ssl/cloudflare-origin.pem
# ORIGIN_KEY_PATH=/etc/ssl/private/cloudflare-origin.key
